@model BuildingFormVM


@section Header{
      create
}
<div class="col-md-12">

<div class="card card-primary">
    <div class="card-header">
        <h3 class="card-title">Create Building</h3>
    </div>


    <form asp-controller="Building" asp-action="create">
        <div class="card-body">
            <div class="form-group">
                <label asp-for="DetailsBuilding"></label>
                <input asp-for="DetailsBuilding" class="form-control">
            </div>
                <div class="form-group">
                    <label asp-for="Price"></label>
                    <input asp-for="Price" class="form-control">
                </div>
                <div class="form-group">
                    <label asp-for="Bedrooms"></label>
                    <input asp-for="Bedrooms" class="form-control">
                </div>
                <div class="form-group">
                    <label asp-for="bathrooms"></label>
                    <input asp-for="bathrooms" class="form-control">
                </div>
                <div class="form-group">
                    <label asp-for="Area"></label>
                    <input asp-for="Area" class="form-control">
                </div>
                <div class="form-group">
                    <label asp-for="Floor"></label>
                    <input asp-for="Floor" class="form-control">
                </div>
                <div class="form-group">
                    <label asp-for="Parking"></label>
                    <input asp-for="Parking" class="form-control">
                </div>
        </div>

        <div class="card-footer">
            <button type="submit" class="btn btn-success">Create</button>
        </div>
    </form>
</div>
</div>
