        //     let table = $('table').DataTable({
        //         dom: 'Bfrtip',  // Ensure the buttons appear on the table
        //         buttons: [
        //             'copy', 'excel', 'pdf'
        //         ]
        //     });
        // });
    </script> *@





    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- DataTables -->
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap4.min.js"></script>

    <!-- DataTables Buttons Extension -->
    <script src="https://cdn.datatables.net/buttons/2.3.6/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.3.6/js/buttons.bootstrap4.min.js"></script>

    <!-- JSZip and pdfmake for export -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.36/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.1.36/vfs_fonts.js"></script>

    <!-- Buttons for exporting options -->
    <script src="https://cdn.datatables.net/buttons/2.3.6/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.3.6/js/buttons.print.min.js"></script>

    <script>
        $(document).ready(function () {
            let table = $('table').DataTable({
                dom: 'Bfrtip',  // Ensure the buttons appear on the table
                buttons: ['excel', 'pdf'
                ]
            });
        });



        const element = document.querySelectorAll('.delete-btn');
        element.forEach((button) => {
            button.addEventListener('click', async () => {
                const isconfirm = confirm("Are you sure you want to delete this building?");
                if (!isconfirm) return;
                const id = button.dataset.id;
                const response = await fetch(`/Dashbord/Building/delete/${id}`, {
                    method: 'POST'
                });
                const data = await response.json()
                if (response.ok) {
                    button.closest('tr').remove();
                }
                else {
                    confirm("error");
                }

            }
            )

        })

    </script>


}